{# backend/scaffolding/templates/dockerfile.j2 #}
# {{ service_name }} — Dockerfile
# Language: {{ language }}

{% if language == "java" %}
FROM eclipse-temurin:{{ java_version | default('17') }}-jdk-alpine AS build
WORKDIR /app
COPY pom.xml .
COPY src ./src
RUN ./mvnw package -DskipTests

FROM eclipse-temurin:{{ java_version | default('17') }}-jre-alpine
WORKDIR /app
COPY --from=build /app/target/*.jar app.jar
EXPOSE {{ port }}
HEALTHCHECK --interval=30s --timeout=3s CMD wget -qO- http://localhost:{{ port }}/actuator/health || exit 1
ENTRYPOINT ["java", "-jar", "app.jar"]
{% else %}
FROM python:{{ python_version | default('3.11') }}-slim
WORKDIR /app
COPY pyproject.toml .
RUN pip install --no-cache-dir .
COPY . .
EXPOSE {{ port }}
HEALTHCHECK --interval=30s --timeout=3s CMD python -c "import httpx; httpx.get('http://localhost:{{ port }}/health')" || exit 1
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "{{ port }}"]
{% endif %}
