{# backend/scaffolding/templates/k8s_deployment.j2 #}
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ service_name | lower | replace(' ', '-') }}
  labels:
    app: {{ service_name | lower | replace(' ', '-') }}
spec:
  replicas: {{ replicas | default(2) }}
  selector:
    matchLabels:
      app: {{ service_name | lower | replace(' ', '-') }}
  template:
    metadata:
      labels:
        app: {{ service_name | lower | replace(' ', '-') }}
    spec:
      containers:
        - name: {{ service_name | lower | replace(' ', '-') }}
          image: {{ image_name }}
          ports:
            - containerPort: {{ port }}
          resources:
            requests:
              cpu: "{{ cpu_request | default('250m') }}"
              memory: "{{ memory_request | default('512Mi') }}"
            limits:
              cpu: "500m"
              memory: "1Gi"
          readinessProbe:
            httpGet:
              path: {{ readiness_path | default('/health') }}
              port: {{ port }}
            initialDelaySeconds: 15
            periodSeconds: 10
          livenessProbe:
            httpGet:
              path: {{ readiness_path | default('/health') }}
              port: {{ port }}
            initialDelaySeconds: 30
            periodSeconds: 15
---
apiVersion: v1
kind: Service
metadata:
  name: {{ service_name | lower | replace(' ', '-') }}-svc
spec:
  type: ClusterIP
  selector:
    app: {{ service_name | lower | replace(' ', '-') }}
  ports:
    - port: {{ port }}
      targetPort: {{ port }}
      protocol: TCP
